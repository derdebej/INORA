#enter the command below in the trerminal to install the required libraries
#pip install opencv-python ultralytics
import cv2
from ultralytics import YOLO

#tekteb path lmodele bin "" w hoto fi nafs lfolder maa lcode
model = YOLO("banknotes.pt")  
# dictionnaire hatina fih l2alwen li bech ycadri bihom kol classe
colors = {
    "5":  (0, 200, 0),
    "10": (255, 100, 0),
    "20": (0, 165, 255),
    "50": (0, 0, 220),
}

cap = cv2.VideoCapture(0)

print("Camera opened! Press Q to quit.\n")

last_total  = -1
last_counts = {}

while True:
    ret, frame = cap.read()
    if not ret:
        print("Camera not found.")
        break

    results = model(frame, conf=0.5, verbose=False) # verbose=False bech lmodel mayeprintich hweyej kol mara ydetecti haja sinon ywalli spam wel conf hia lconfiance minimal mta lmodel bech ykaatik resultat w ywalli ydetecti les objets li 3andha confiace 0.5 w akther
    result  = results[0]    # results hia liste  fiha les objets li detitehom houni fiha item bark khater dakhalna frame wehed lel model

    total  = 0
    counts = {}

    for box in result.boxes: #results.boxes hia liste fiha lehweyej li detectehom lmodel
        cls_name        = model.names[int(box.cls[0])] # box.cls[0] hia class index li detecteh lmodel w model.names hia liste fiha les noms mta3 les classes
        conf            = float(box.conf[0])
        value           = float(cls_name)
        x1, y1, x2, y2 = map(int, box.xyxy[0].tolist()) # box.xyxy[0] hia les coordonnees du bounding box w.tolist() bech yconvertiha lel liste wel maps trodhom mel float lel int
        color           = colors.get(cls_name, (255, 255, 255)) #yekhou lcouleur mta lbox mel dictionnaire lfouk wken mouch mawjoud ywalli lbox abyadh

        total += value
        counts[cls_name] = counts.get(cls_name, 0) + 1

        # Draw box
        cv2.rectangle(frame, (x1, y1), (x2, y2), color, 2)

        # Draw label
        label = f"{cls_name} dt {conf:.0%}"
        (w, h), _ = cv2.getTextSize(label, cv2.FONT_HERSHEY_SIMPLEX, 0.7, 2)
        cv2.rectangle(frame, (x1, y1-30), (x1+w+8, y1), color, -1)
        cv2.putText(frame, label, (x1+4, y1-8),
                    cv2.FONT_HERSHEY_SIMPLEX, 0.7, (255, 255, 255), 2)

    # Draw total bar at top of camera window
    cv2.rectangle(frame, (0, 0), (frame.shape[1], 50), (0, 0, 0), -1)
    cv2.putText(frame, f"TOTAL: {total:.0f} dt  |  Notes: {len(result.boxes)}",
                (15, 35), cv2.FONT_HERSHEY_SIMPLEX, 1.1, (0, 255, 180), 2)

    # Show camera window
    cv2.imshow("Currency Detector", frame)

    # Print to terminal only when total or notes change
    if total != last_total or counts != last_counts:
        print("="*35)
        if len(counts) == 0:
            print("  No currency detected.")
        else:
            for note, qty in sorted(counts.items(), key=lambda x: float(x[0])):
                print(f"  {note} dt  x{qty}  =  {float(note)*qty:.0f} dt")
            print("-"*35)
            print(f"  TOTAL  →  {total:.0f} dt")
        print("="*35 + "\n")

        last_total  = total
        last_counts = counts.copy()

    # Press Q to quit
    if cv2.waitKey(1) & 0xFF == ord("q"):
        break

cap.release()
cv2.destroyAllWindows()
print("Camera closed.")